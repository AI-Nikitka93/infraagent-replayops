# InfraAgent runtime environment example.
# Copy this file to `.env` on the AMD VM and generate real secrets before running scripts.
#
# Secret generation:
#   openssl rand -hex 32
#
# Recommended setup:
#   cp .env.example .env
#   sed -i "s/CHANGE_ME_VLLM_API_KEY/$(openssl rand -hex 32)/" .env
#   sed -i "s/CHANGE_ME_PUBLIC_API_KEY/$(openssl rand -hex 32)/" .env

# Optional for Hugging Face Hub downloads. Leave empty if the model download works anonymously.
HF_TOKEN=

# Secrets used by vLLM and the future FastAPI/LangGraph service.
VLLM_API_KEY=CHANGE_ME_VLLM_API_KEY
PUBLIC_API_KEY=CHANGE_ME_PUBLIC_API_KEY

# Local inference endpoint exposed only on the AMD VM loopback interface.
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_HEALTH_URL=http://127.0.0.1:8000/v1/models

# Future LangGraph/FastAPI endpoint. Cloudflare Tunnel exposes this service, not raw vLLM.
LANGGRAPH_HOST=127.0.0.1
LANGGRAPH_PORT=8010
LANGGRAPH_BASE_URL=http://127.0.0.1:8010
LANGGRAPH_HEALTH_URL=http://127.0.0.1:8010/health

# Hugging Face Spaces UI secrets. Set these in Space settings, not in the repo.
INFRAAGENT_API_BASE=https://CHANGE_ME.trycloudflare.com
INFRAAGENT_API_KEY=CHANGE_ME_PUBLIC_API_KEY
INFRAAGENT_POLL_INTERVAL_SECONDS=2
INFRAAGENT_MAX_POLL_ATTEMPTS=60

# Hugging Face cache mounted into the vLLM ROCm container.
HF_CACHE=/mnt/data/huggingface-cache

# vLLM serving profile from docs/research-report.md.
VLLM_IMAGE=vllm/vllm-openai-rocm:v0.20.1
VLLM_CONTAINER_NAME=infraagent-vllm-qwen25-72b
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct
VLLM_SERVED_MODEL_NAME=qwen2.5-72b-instruct
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_DTYPE=bfloat16
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_NUM_SEQS=16

# Startup wait windows. First model download can be slow.
VLLM_STARTUP_TIMEOUT_SECONDS=2400
VLLM_HEALTH_POLL_SECONDS=10
LANGGRAPH_STARTUP_TIMEOUT_SECONDS=120
LANGGRAPH_HEALTH_POLL_SECONDS=2

# Cloudflare Quick Tunnel settings.
CLOUDFLARED_TARGET_URL=http://localhost:8010
CLOUDFLARED_LOG_FILE=.runtime/cloudflared-quick-tunnel.log
CLOUDFLARED_BIN=cloudflared
CLOUDFLARED_PROTOCOL=http2
